# Local development server port (default: 3001)
PORT=3001

# Scryfall API rate limiting — minimum ms between requests (default: 100)
SCRYFALL_RATE_LIMIT_MS=100

# Firebase Admin SDK — local dev without emulators (npm run dev:server)
# The Admin SDK auto-configures in Cloud Functions. For local use choose one:
#   Option A: Point to a service account key downloaded from Firebase Console
#             Project Settings → Service accounts → Generate new private key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
#
#   Option B: Already authenticated via `firebase login` — ADC picks it up automatically.
#             No variable needed.

# Emulator overrides — set automatically by `firebase emulators:start`.
# Uncomment only if running Admin SDK against emulators without the Firebase CLI.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
