// Local development rules — permissive for emulator use only.
// Production rules live in firebase-robbchar-config/firestore.rules and are
// deployed separately. These are never deployed to production.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
